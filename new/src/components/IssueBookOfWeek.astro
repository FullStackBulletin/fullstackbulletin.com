---
import { resolveImage } from '../lib/resolveImage';
import { renderSimpleMarkdown } from '../lib/markdown';
import { addUtmParams } from '../lib/utm';

interface Props {
  title: string;
  author: string | null;
  description: string | null;
  coverImageUrl: string | null;
  amazonUs: string | null;
  amazonUk: string | null;
  slug: string;
  issueNumber: number;
}

const { title, author, description, coverImageUrl, amazonUs, amazonUk, slug, issueNumber } = Astro.props;
const resolvedCover = resolveImage(coverImageUrl, slug);
const trackedAmazonUs = amazonUs ? addUtmParams(amazonUs, issueNumber, 'amazon-us') : null;
const trackedAmazonUk = amazonUk ? addUtmParams(amazonUk, issueNumber, 'amazon-uk') : null;
---

<section class="my-8 p-5 bg-neutral-lightest">
  <h3 class="font-heading text-sm font-semibold uppercase tracking-wider text-neutral-medium mb-4 title-bar">
    Book of the week
  </h3>
  <div class="flex flex-col sm:flex-row gap-5">
    {resolvedCover && (
      <div class="flex-shrink-0">
        <img
          src={resolvedCover}
          alt={title}
          class="w-24 h-auto shadow-sm"
          loading="lazy"
        />
      </div>
    )}
    <div>
      <h4 class="font-heading text-base font-semibold mb-1">{title}</h4>
      {author && (
        <p class="text-sm text-neutral-medium mb-2">by {author}</p>
      )}
      {description && (
        <p class="text-sm text-neutral-dark leading-relaxed mb-3" set:html={renderSimpleMarkdown(description, issueNumber, 'description-link')} />
      )}
      <div class="flex gap-3">
        {trackedAmazonUs && (
          <a
            href={trackedAmazonUs}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-4 h-11 bg-brand-primary text-neutral-darkest font-heading text-xs font-semibold uppercase hover:bg-brand-dark transition-colors"
          >
            Amazon US
          </a>
        )}
        {trackedAmazonUk && (
          <a
            href={trackedAmazonUk}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-4 h-11 bg-brand-primary text-neutral-darkest font-heading text-xs font-semibold uppercase hover:bg-brand-dark transition-colors"
          >
            Amazon UK
          </a>
        )}
      </div>
    </div>
  </div>
</section>
