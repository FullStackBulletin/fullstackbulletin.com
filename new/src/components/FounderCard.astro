---
interface Props {
  name: string;
  image: string;
  description: string;
  profiles: { label: string; url: string }[];
}

const { name, image, description, profiles } = Astro.props;
---

<div class="flex flex-row gap-4">
  <!-- Image column -->
  <div class="flex-shrink-0 w-1/3 md:w-auto">
    <div class="max-w-[200px]">
      <img
        src={`/images/founders/${image}`}
        alt={name}
        class="w-full block"
      />
    </div>
  </div>

  <!-- Content column -->
  <div class="flex-1">
    <h3 class="font-heading text-base md:text-lg font-semibold mt-4">{name}</h3>
    <p class="text-sm text-neutral-dark mt-2">{description}</p>
    <div class="mt-3">
      {profiles.map((profile) => (
        <a
          href={profile.url}
          target="_blank"
          rel="noopener noreferrer"
          class="founder-profile-link relative block text-sm leading-none mt-4 first:mt-0"
        >
          {profile.label}
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .founder-profile-link::before {
    content: '';
    display: block;
    position: absolute;
    bottom: -8px;
    width: 30px;
    height: 4px;
    background-color: var(--color-brand-primary);
  }
</style>
