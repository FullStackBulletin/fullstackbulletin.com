---
interface Props {
  title: string;
  description: string;
  index: number;
}

const { title, description, index } = Astro.props;
---

<div class="faq-item inline-block w-full mb-6">
  <details class="group">
    <summary class="faq-title relative flex items-center cursor-pointer list-none [&::-webkit-details-marker]:hidden">
      <span class="faq-count relative z-[1] bg-neutral-lightest pr-2.5">
        <span class="w-[30px] h-[30px] flex items-center justify-center bg-brand-primary text-neutral-darkest text-xs font-heading font-semibold">
          {index + 1}
        </span>
      </span>
      <span class="faq-label relative z-[1] bg-neutral-lightest pl-1 pr-2.5 font-heading text-sm font-semibold underline leading-none hover:text-brand-dark">
        {title}
      </span>
    </summary>
    <div class="faq-description mt-5 text-sm text-neutral-dark leading-relaxed" set:html={description} />
  </details>
</div>

<style>
  .faq-title::before {
    content: '';
    width: 100%;
    border-bottom: 1px dashed var(--color-neutral-medium);
    position: absolute;
    top: 50%;
    left: 0;
  }

  .faq-description :global(a) {
    font-weight: 700;
    text-decoration: underline;
  }
</style>
