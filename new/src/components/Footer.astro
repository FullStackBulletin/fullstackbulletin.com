---
import { footer, meta, navigation } from '../data/site';
---

<footer class="bg-white text-neutral-medium py-12 px-4">
  <div class="max-w-4xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
      <!-- Primary: logo + description + navigation -->
      <div>
        <a href="/" class="inline-block leading-none">
          <img src="/images/logo.svg" alt="FullStack Bulletin" class="w-[130px] md:w-[134px] huge:w-[178px]" />
        </a>
        <p class="text-sm leading-relaxed mt-6">
          {footer.description}
        </p>
        <div class="flex flex-wrap items-center gap-x-1 mt-4">
          {navigation.map((item, i) => (
            <>
              {i > 0 && <span class="hidden md:inline text-neutral-medium mx-2">/</span>}
              <a
                href={item.link}
                class="text-sm text-neutral-dark underline py-1 block"
              >
                {item.label}
              </a>
            </>
          ))}
        </div>
      </div>

      <!-- Secondary: credits + feedback -->
      <div>
        <p class="text-sm leading-relaxed" set:html={footer.sub} />
        <div class="mt-4">
          <p class="text-sm">
            {footer.feedback.text}
          </p>
          <a
            href={footer.feedback.url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center px-6 h-11 bg-brand-primary text-neutral-darkest font-heading text-sm font-semibold uppercase mt-5 hover:bg-brand-dark transition-colors"
          >
            {footer.feedback.label}
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
