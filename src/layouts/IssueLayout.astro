---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  issueNumber: number;
  date: string;
  description?: string;
  prevSlug?: string | null;
  nextSlug?: string | null;
}

const { title, issueNumber, date, description, prevSlug, nextSlug } = Astro.props;

const formattedDate = new Date(date + 'T00:00:00').toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`Issue #${issueNumber}: ${title}`} description={description}>
  <Header />
  <main class="pt-8 pb-16" data-pagefind-body>
    <div class="max-w-[700px] mx-auto px-4 issue-content">
      <header class="mb-8">
        <div class="text-sm text-neutral-medium mb-2" data-pagefind-meta={`date:${formattedDate}`}>
          Issue #{issueNumber} &middot; {formattedDate}
        </div>
        <h1 class="font-heading text-3xl md:text-4xl font-semibold leading-tight">
          {title}
        </h1>
      </header>

      <slot />

      <nav class="mt-12 pt-8 border-t border-neutral-light/50 flex justify-between items-center" aria-label="Issue navigation" data-pagefind-ignore>
        {prevSlug ? (
          <a href={`/archive/${prevSlug}`} class="font-heading text-sm font-semibold hover:text-brand-dark">
            &larr; Previous issue
          </a>
        ) : <span />}
        <a href="/archive" class="font-heading text-sm text-neutral-medium hover:text-brand-dark">
          All issues
        </a>
        {nextSlug ? (
          <a href={`/archive/${nextSlug}`} class="font-heading text-sm font-semibold hover:text-brand-dark">
            Next issue &rarr;
          </a>
        ) : <span />}
      </nav>
    </div>
  </main>
  <Footer />
</BaseLayout>
