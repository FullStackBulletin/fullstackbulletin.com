---
import { addUtmParams } from '../lib/utm';

interface Props {
  text: string;
  author: string | null;
  authorTitle: string | null;
  authorUrl: string | null;
  issueNumber: number;
}

const { text, author, authorTitle, authorUrl, issueNumber } = Astro.props;
const trackedAuthorUrl = authorUrl ? addUtmParams(authorUrl, issueNumber, 'quote-author') : null;
---

<blockquote class="border-l-4 border-brand-primary pl-6 py-2 my-8 bg-neutral-lightest p-5 rounded-r">
  <p class="font-body text-base md:text-lg italic text-neutral-darkest leading-relaxed">
    &ldquo;{text}&rdquo;
  </p>
  {author && (
    <footer class="mt-3 font-body text-sm text-neutral-dark">
      &mdash;{' '}
      {authorUrl ? (
        <a href={trackedAuthorUrl} target="_blank" rel="noopener noreferrer" class="text-brand-dark">
          {author}
        </a>
      ) : (
        <span>{author}</span>
      )}
      {authorTitle && <span>, {authorTitle}</span>}
    </footer>
  )}
</blockquote>
