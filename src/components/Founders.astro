---
import FounderCard from './FounderCard.astro';
import { founders } from '../data/site';
---

<section class="pb-12 md:pb-16 px-4 bg-neutral-lightest">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-heading text-2xl md:text-3xl font-semibold title-bar mb-8">
      {founders.title}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {founders.entries.map((founder) => (
        <FounderCard
          name={founder.name}
          image={founder.image}
          description={founder.description}
          profiles={founder.profiles}
        />
      ))}
    </div>
  </div>
</section>
