---
import FaqItem from './FaqItem.astro';
import { faq } from '../data/site';
---

<section class="py-16 md:py-20 px-4 bg-neutral-lightest">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-heading text-2xl md:text-3xl font-semibold title-bar mb-8">
      {faq.title}
    </h2>
    <div class="faq-columns">
      {faq.entries.map((entry, i) => (
        <FaqItem title={entry.title} description={entry.description} index={i} />
      ))}
    </div>
  </div>
</section>

<style>
  .faq-columns {
    @media (min-width: 768px) {
      column-count: 2;
      column-gap: 2rem;
    }
  }
</style>
