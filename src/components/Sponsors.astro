---
import { sponsors } from '../data/site';
---

<section class="py-8 px-4 bg-black">
  <div class="max-w-4xl mx-auto">
    <h2 class="font-heading text-2xl md:text-3xl font-semibold text-white title-bar mb-8">
      Past sponsors
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {sponsors.map((sponsor) => (
        <a
          href={sponsor.link}
          target="_blank"
          rel="noopener noreferrer"
          class="opacity-70 hover:opacity-100 transition-opacity"
          title={sponsor.name}
        >
          <img
            src={`/images/sponsors/${sponsor.logo}`}
            alt={sponsor.name}
            class="h-10 md:h-12 w-auto max-w-[140px] object-contain"
          />
        </a>
      ))}
    </div>
  </div>
</section>
